# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_bot_application_id_here
OWNER_ID=your_discord_user_id_here

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/toolmetry
# Or use MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/toolmetry

# Server Configuration
PORT=5000
NODE_ENV=development

# Optional: Client URL for CORS (if using dashboard)
CLIENT_URL=http://localhost:3000

# Staff Role IDs (for ticket management - comma separated)
STAFF_ROLE_IDS=role_id_1,role_id_2

# Support Email (for AI responses)
SUPPORT_EMAIL=support@yourdomain.com

# Support Server URL (for ticket panel button)
SUPPORT_SERVER_URL=https://discord.gg/yourserver
